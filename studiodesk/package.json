{
  "name": "studiodesk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "vitest run --dir tests/unit",
    "test:api": "vitest run --dir tests/api",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:verbose": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "db:seed": "npx ts-node --project supabase/tsconfig.seed.json supabase/seed.ts",
    "db:reset:seed": "npx supabase db reset && npm run db:seed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.0",
    "razorpay": "^2.9.6",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.2",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "jsdom": "^29.0.0",
    "next-test-api-route-handler": "^5.0.3",
    "pg": "^8.20.0",
    "postcss": "^8",
    "supabase": "^2.81.2",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
